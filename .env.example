# Required: your Google Generative AI (Google AI Studio) API key.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: model id (defaults to gemini-2.5-flash).
GOOGLE_MODEL=gemini-2.5-flash

# Optional: override the API endpoint (e.g. a proxy or gateway).
# Must be a full URL. Leave empty to use the default Google endpoint.
BASE_URL=
